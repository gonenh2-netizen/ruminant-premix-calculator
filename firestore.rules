rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Each authenticated user owns their subtree. Nobody else can read or write.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /formulations/{formulationId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // No other collections are readable or writable.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
