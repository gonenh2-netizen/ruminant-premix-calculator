# Firebase web-app config — copy to `.env.local` and fill in from
# Firebase Console → Project settings → Your apps → Web app → SDK setup.
#
# These values are PUBLIC (they ship in the built HTML); access control
# is enforced by firestore.rules, not by hiding the config.
#
# Leave everything blank to run the app in OFFLINE mode (localStorage only,
# no login gate).

VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_APP_ID=
